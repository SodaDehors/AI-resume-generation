# ============================================================
# 生产环境配置 — 复制为 .env 并填入真实值
# ============================================================

# Flask 密钥（务必修改！用 python -c "import secrets; print(secrets.token_hex(32))" 生成）
SECRET_KEY=change-me-to-a-random-string

# AI Provider 选择：deepseek / claude / openai
DEFAULT_AI_PROVIDER=deepseek

# API Keys（至少填一个）
DEEPSEEK_API_KEY=sk-xxx
# ANTHROPIC_API_KEY=sk-ant-xxx
# OPENAI_API_KEY=sk-xxx

# Session 存储目录（默认 /tmp/ai_resume_sessions）
# SESSION_FILE_DIR=/tmp/ai_resume_sessions
